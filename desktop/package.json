{
  "name": "deeplab-desktop",
  "version": "0.1.0",
  "description": "DeepLab desktop host built with Electron",
  "private": true,
  "main": "main.js",
  "author": {"name": "timechess", "email": "tyc221@ruc.edu.cn"},
  "license": "MIT",
  "homepage": "https://github.com/timechess/DeepLab",
  "repository": {"url": "https://github.com/timechess/DeepLab"},
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "prepare:frontend": "node scripts/prepare-frontend.mjs",
    "prepare:backend": "node scripts/prepare-backend-runtime.mjs",
    "prepare:bundle": "npm run clean && npm run prepare:frontend && npm run prepare:backend",
    "start": "npm run prepare:bundle && electron .",
    "pack:win": "npm run prepare:bundle && node scripts/run-electron-builder.mjs --win nsis --x64 --dir",
    "pack:mac": "npm run prepare:bundle && node scripts/run-electron-builder.mjs --mac dmg zip --dir",
    "pack:linux": "npm run prepare:bundle && node scripts/run-electron-builder.mjs --linux AppImage deb --dir",
    "dist:win": "npm run prepare:bundle && node scripts/run-electron-builder.mjs --win nsis --x64",
    "dist:mac": "npm run prepare:bundle && node scripts/run-electron-builder.mjs --mac dmg zip",
    "dist:linux": "npm run prepare:bundle && node scripts/run-electron-builder.mjs --linux AppImage deb",
    "dist:all": "npm run prepare:bundle && node scripts/run-electron-builder.mjs --win nsis --x64 --mac dmg zip --linux AppImage deb",
    "desktop:dist:win": "npm run dist:win",
    "desktop:dist:mac": "npm run dist:mac",
    "desktop:dist:linux": "npm run dist:linux",
    "icon": "eib  -i icon.png -o build/icons --flatten"
  },
  "devDependencies": {
    "@hunlongyu/electron-icon-builder": "^0.1.5",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "fs-extra": "^11.3.4"
  },
  "build": {
    "appId": "com.deeplab.desktop",
    "productName": "DeepLab",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".bundle/backend-src",
        "to": "backend-src"
      },
      {
        "from": ".bundle/backend-venv",
        "to": "backend-venv"
      },
      {
        "from": ".bundle/backend-python",
        "to": "backend-python"
      },
      {
        "from": ".bundle/frontend-standalone",
        "to": "frontend-standalone"
      },
      {
        "from": "build/icons/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icons/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icons/icon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
