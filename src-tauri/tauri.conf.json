{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepLab",
  "version": "1.0.4",
  "identifier": "deeplab",
  "build": {
    "beforeDevCommand": "pnpm dev:next",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build:next",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeepLab",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:deeplab.sqlite"
      ]
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBRDA4QkY2Q0IyNkIyMDIKUldRQ3NpYkw5b3ZRcWpqTEdSSCs5SWMvWU55dkFweWJaT25xajFsMFV4SmdSUC85NS8yNXo0ZCsK",
      "endpoints": [
        "https://github.com/timechess/DeepLab/releases/latest/download/latest.json"
      ]
    }
  }
}
