{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepLab",
  "version": "1.0.0",
  "identifier": "deeplab",
  "build": {
    "beforeDevCommand": "pnpm dev:next",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build:next",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeepLab",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:deeplab.sqlite"
      ]
    }
  }
}
